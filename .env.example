# BridgeLearn V15 — Environment Variables
# Copy this file to .env.local and fill in your values
# For browser-based deploy: set these as window.BL_CONFIG in a config.js file

# ── Firebase ─────────────────────────────────────────────────────
FIREBASE_API_KEY=your-firebase-api-key
FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_STORAGE_BUCKET=your-project.appspot.com
FIREBASE_MESSAGING_SENDER_ID=123456789
FIREBASE_APP_ID=1:123456789:web:abcdef

# ── AI Provider (pick one or add fallback chain) ──────────────────
# Option A: Anthropic Claude
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Option B: OpenAI
OPENAI_API_KEY=sk-your-openai-key

# Option C: Your own BridgeSpeak backend
BRIDGE_BACKEND_URL=https://your-backend.vercel.app/api/chat

# ── Feature Flags ─────────────────────────────────────────────────
ENABLE_VOICE=true
ENABLE_PARENT_MODE=true
ENABLE_TEACHER_MODE=true
ENABLE_ANALYTICS=false
