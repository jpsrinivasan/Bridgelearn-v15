# ─── BridgeLearn Auth Server — Environment Variables ───────────────
# Copy this file to .env and fill in the values.
# NEVER commit .env to git.

# ── Server ──────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development         # development | production

# ── App URL (used in email links) ───────────────────────────────────
APP_URL=http://localhost:5175

# ── CORS (comma-separated list of allowed SPA origins) ──────────────
ALLOWED_ORIGINS=http://localhost:5175,http://localhost:3000

# ── JWT Secrets — CHANGE THESE — use: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=REPLACE_WITH_64_BYTE_RANDOM_HEX_STRING
JWT_REFRESH_SECRET=REPLACE_WITH_DIFFERENT_64_BYTE_RANDOM_HEX_STRING

# ── SMTP (leave blank to use console logging in dev) ────────────────
# SMTP_HOST=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=apikey
# SMTP_PASS=your_sendgrid_api_key
# SMTP_FROM=noreply@bridgelearn.app
